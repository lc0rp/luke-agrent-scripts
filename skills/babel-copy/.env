# Babel Copy environment template
#
# Notes
# - `scripts/translate_blocks_codex.py` reads `.env` from the translation working directory.
#   This file is a documented template in `skills/babel-copy/`; copy or source it where needed.
# - Leave secrets empty here. Fill them locally when you actually run the workflow.
# - Comment format per var:
#   var | source | default | used by | precedence
#
# Translation
#
# OPENAI_API_KEY | cwd .env or inherited env | none | scripts/translate_blocks_codex.py | cwd .env > inherited env
# Short desc: OpenAI fallback credential. Used after `codex exec` fails, or directly when `BABEL_COPY_TRANSLATION_PROVIDER=openai`.
# Options: any valid OpenAI API key; placeholder and too-short values are skipped.
OPENAI_API_KEY=

# BABEL_COPY_TRANSLATION_PROVIDER | env | auto | scripts/translate_blocks_codex.py | env > auto
# Short desc: Selects the translation backend strategy.
# Options: auto, openai, google
BABEL_COPY_TRANSLATION_PROVIDER=auto

# BABEL_COPY_OPENAI_MODEL | env | gpt-5.4-mini | scripts/translate_blocks_codex.py | --model CLI arg > env > default
# Short desc: Model used for the OpenAI Responses fallback path.
# Options: any OpenAI Responses API model name supported by your account.
BABEL_COPY_OPENAI_MODEL=gpt-5.4-mini

# CODEX_MODEL | env | none in babel-copy logic | scripts/translate_blocks_codex.py | --model CLI arg > BABEL_COPY_OPENAI_MODEL > CODEX_MODEL > "default" (log context only)
# Short desc: Observed for auth/log context in this skill. It does not override the actual OpenAI fallback model selection.
# Options: any Codex model string if you want log metadata to reflect it.
CODEX_MODEL=

# OCR
#
# BABEL_COPY_OCR_ENGINE | env | tesseract | scripts/core.py | explicit arg / CLI value > env > default
# Short desc: OCR backend for extraction.
# Options: tesseract, tess, paddle, paddleocr
BABEL_COPY_OCR_ENGINE=tesseract

# BABEL_COPY_PADDLE_PYTHON | env | none | scripts/core.py | --paddle-python CLI arg > env > .venv-babel-paddle/bin/python > .venv-babel-paddle/bin/python3
# Short desc: Python interpreter for the PaddleOCR side environment.
# Options: absolute path to the Paddle venv Python binary.
BABEL_COPY_PADDLE_PYTHON=

# BABEL_COPY_OCR_LANG | env | eng | scripts/core.py | explicit arg / CLI value > env > default
# Short desc: OCR language hint. Tesseract uses the raw value; Paddle normalizes common English/French aliases.
# Options: eng, en, english, fra, fre, fr, french, or another installed Tesseract language code.
BABEL_COPY_OCR_LANG=eng

# BABEL_COPY_OCR_PSM | env | 4 | scripts/core.py | explicit arg / CLI value > env > default
# Short desc: Tesseract page segmentation mode.
# Options: any Tesseract PSM value as a string; common values include 3, 4, 6, 11.
BABEL_COPY_OCR_PSM=4

# Fragment merge
#
# BABEL_COPY_ENABLE_LLM_FRAGMENT_MERGE | env | 1 | scripts/extract_document.py | env > default
# Short desc: Enables the LLM-assisted merge pass for ambiguous extracted fragments.
# Options: enabled for 1, true, yes, on; anything else disables it.
BABEL_COPY_ENABLE_LLM_FRAGMENT_MERGE=1

# BABEL_COPY_FRAGMENT_MERGE_MODEL | env | none | scripts/extract_document.py | env > none
# Short desc: Optional model override for fragment-merge Codex calls.
# Options: any model string accepted by the fragment-merge caller.
BABEL_COPY_FRAGMENT_MERGE_MODEL=

# Setup helper
#
# PYTHON_BIN | env | python3.11 | scripts/setup_paddle_env.sh | env > default
# Short desc: Interpreter used to create the Paddle OCR virtualenv.
# Options: python3.11, python3.12, or another compatible Python on PATH.
PYTHON_BIN=python3.11

# Non-env script parameter reference
# TARGET_DIR | positional arg | $PWD/.venv-babel-paddle | scripts/setup_paddle_env.sh | first positional arg > default
