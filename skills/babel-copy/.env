# Babel Copy environment template
#
# Notes
# - Profiling-aware babel-copy scripts read `.env` from the translation working directory first,
#   then fall back to `skills/babel-copy/.env`.
#   This file is a documented template in `skills/babel-copy/`; copy or source it where needed.
# - Leave secrets empty here. Fill them locally when you actually run the workflow.
# - Comment format per var:
#   var | source | default | used by | precedence
#
# Translation
#
# BABEL_COPY_RUNTIME_MODE | env | auto-detect | scripts/translate_blocks_desktop.py | env > auto-detect
# Short desc: Explicitly selects which LLM family to treat as primary
# Options: codex, claude
BABEL_COPY_RUNTIME_MODE=

# BABEL_COPY_TRANSLATION_PROVIDER | env | auto | scripts/translate_blocks_desktop.py | env > auto
# Short desc: Selects the desktop translation backend strategy.
# Options: auto, codex, claude
BABEL_COPY_TRANSLATION_PROVIDER=auto

# Profiling
#
# ENABLE_PROFILER | env | disabled | instrumented babel-copy scripts | explicit CLI --profiler > env > disabled
# Short desc: Enables structured profiling output for benchmark runs.
# Options: 1, true, yes, on to enable; anything else disables it.
ENABLE_PROFILER=

# PROFILER_COMMANDS | env | all | instrumented babel-copy scripts | explicit CLI --profiler-commands > env > all
# Short desc: Comma-separated command list to profile. Empty means all instrumented commands.
# Options: empty, all, or a comma-separated list such as extract_document,build_final_pdf,translate_blocks_desktop-prepare
PROFILER_COMMANDS=

# PROFILER_OUTPUT_DIR | env | profiles | instrumented babel-copy scripts | explicit CLI --profiler-output-dir > env > profiles
# Short desc: Base directory for profiler output. Each run writes to <dir>/run-{timestamp}/{command}.json.
# Options: absolute or relative directory path.
PROFILER_OUTPUT_DIR=

# BABEL_COPY_OCR_LANG | env | eng | scripts/core.py | explicit arg / CLI value > env > default
# Short desc: OCR language hint. Tesseract uses the raw value;
# Options: eng, en, english, fra, fre, fr, french, or another installed Tesseract language code.
BABEL_COPY_OCR_LANG=eng

# BABEL_COPY_OCR_PSM | env | 4 | scripts/core.py | explicit arg / CLI value > env > default
# Short desc: Tesseract page segmentation mode.
# Options: any Tesseract PSM value as a string; common values include 3, 4, 6, 11.
BABEL_COPY_OCR_PSM=4

# Fragment merge
#
# BABEL_COPY_ENABLE_LLM_FRAGMENT_MERGE | env | 1 | scripts/extract_document.py | env > default
# Short desc: Enables the LLM-assisted merge pass for ambiguous extracted fragments.
# Options: enabled for 1, true, yes, on; anything else disables it.
BABEL_COPY_ENABLE_LLM_FRAGMENT_MERGE=1

# BABEL_COPY_FRAGMENT_MERGE_MODEL | env | none | scripts/extract_document.py | env > none
# Short desc: Optional model override for fragment-merge Codex calls.
# Options: any model string accepted by the fragment-merge caller.
BABEL_COPY_FRAGMENT_MERGE_MODEL=
